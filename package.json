{
  "name": "fedramp-ret-tool",
  "version": "1.0.0",
  "description": "FedRAMP 3PAO Automated Vulnerability Scan Ingestion Tool — RET Workbook v2.5 Automation",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"webpack serve --config webpack.renderer.config.js\" \"wait-on http://localhost:9000 && electron .\"",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build": "npm run build:renderer && electron-builder --win --mac"
  },
  "build": {
    "appId": "com.fedramp.ret-tool",
    "productName": "FedRAMP RET Tool",
    "files": [
      "src/main/**/*",
      "dist/**/*",
      "assets/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  },
  "dependencies": {
    "csv-parse": "^5.5.0",
    "exceljs": "^4.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^1.8.10",
    "uuid": "^9.0.0",
    "xml2js": "^0.6.2",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.0",
    "autoprefixer": "^10.4.0",
    "babel-loader": "^9.1.0",
    "concurrently": "^8.2.0",
    "css-loader": "^6.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "html-webpack-plugin": "^5.6.0",
    "postcss": "^8.4.0",
    "postcss-loader": "^8.1.0",
    "style-loader": "^3.3.0",
    "tailwindcss": "^3.4.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.0.0"
  }
}
